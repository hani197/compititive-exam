  <script type="text/javascript">

    $(document).ready(function () {
      //     $('.crs').click(function() {
      //       var crs = $(this).attr('crs');
      //            $('#crs'+crs).slideToggle("fast");
      //             $('.crs-list').css("display","none");
      //             $('#crs'+crs).css("display","block");
      //     });
      // });
      $('div.crs-main').each(function () {
        var $dropdown = $(this);

        $("h1.crs-bg", $dropdown).click(function (e) {
          e.preventDefault();
          $div = $("div.crs-fn", $dropdown);
          $div.toggle();
          $("div.crs-fn").not($div).hide();
          return false;
        });

      });

      $('html').click(function () {
        $("div.crs-fn").hide();
      });

    });

  </script>

  <script type="text/javascript">

    $(document).ready(function () {

      $('div.flip-card').each(function () {
        var $dropdown = $(this);

        $("a.dropbtn", $dropdown).click(function (e) {
          e.preventDefault();
          $div = $("div.dropdown-content", $dropdown);
          $div.toggle();
          $("div.dropdown-content").not($div).hide();
          return false;
        });

      });

      $('html').click(function () {
        $("div.dropdown-content").hide();
      });

    });

  </script>
