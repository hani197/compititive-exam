/* The container  - needed to position the dropdown content */
.course-land .dropdown {
    position: relative;
    cursor:pointer;
}

/* Dropdown Content (Hidden by Default) */
.course-land .dropdown-content {
    display: none;
    top:65px;
    position: absolute;
    background-color: #f9f9f9;
    min-width: 250px;
    z-index:9;
    box-shadow: 0px 8px 16px 0px rgba(0,0,0,0.2);
}

/* Links inside the dropdown */
.course-land .dropdown-content a {
    color: black;
       font-size: 13px;
        padding: 12px 18px;
    text-decoration: none;
    text-align: left;
    display: list-item;
}
.course-land .dropdown-content li {
   border-bottom:1px solid #fe2e00;
}
/* Change color of dropdown links on hover */


/* Show the dropdown menu on hover */
.course-land .dropdown:hover .dropdown-content {
 
}

/* Change the background color of the dropdown button when the dropdown content is shown */
.course-land .dropdown:hover .dropbtn {
    background-color: #fe2e00;
}
